# ---- Database (MySQL — shared / cPanel hosting) ----
# Format: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/justbeginyoga"

# ---- Admin session ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Seed credentials for the first admin user (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@justbeginyoga.in"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Anusha Shetty"

# ---- Public site URL (used for canonical URLs, sitemap, OG) ----
NEXT_PUBLIC_SITE_URL="https://justbeginyoga.in"

# ---- Integrations (phase 2 — wired but inert until set) ----
# Google Analytics (GA4). Leave blank to disable.
NEXT_PUBLIC_GA_ID=""
# Google Search Console HTML-tag verification token. Leave blank to disable.
NEXT_PUBLIC_GSC_VERIFICATION=""
# Razorpay. Set ENABLED=true and the keys to turn on checkout.
NEXT_PUBLIC_RAZORPAY_ENABLED="false"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
